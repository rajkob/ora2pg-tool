# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
#   cp .env.example .env
#   chmod 600 .env

# Oracle source password (referenced in ora2pg.conf as ENV{ORA_PWD})
ORA_PWD=changeme

# PostgreSQL target password (referenced in ora2pg.conf as ENV{PG_PWD})
PG_PWD=changeme
